{
  "name": "glyph",
  "version": "1.0.0",
  "description": "Premium PDF Book Reader",
  "type": "module",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run build:main && wait-on http://localhost:5173 && npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "cross-env NODE_ENV=development electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:main && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "lint": "eslint src/ --ext .ts,.tsx",
    "start": "electron ."
  },
  "keywords": ["pdf", "reader", "ebook", "electron"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-toggle": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.10",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "electron": "^42.5.0",
    "flexsearch": "^0.8.212",
    "framer-motion": "^12.42.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "postcss": "^8.5.15",
    "tsx": "^4.20.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
